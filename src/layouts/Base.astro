---
// Layout base — topbar + nav + footer + toggles de idioma/moneda
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** ruta activa para resaltar en nav, p.ej. "/servicios/" */
  active?: string;
}

const { title, description, active = '/' } = Astro.props;

const nav = [
  { href: '/', es: 'Inicio', en: 'Home' },
  { href: '/servicios/', es: 'Servicios', en: 'Services' },
  { href: '/sobre-mi/', es: 'Sobre mí', en: 'About' },
  { href: '/contacto/', es: 'Contacto', en: 'Contact' },
];

const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="canonical" href={canonical}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content="https://www.galjureconsulting.com/photo.jpg">
<meta name="twitter:card" content="summary">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand"><img src="/logo.svg" alt="" aria-hidden="true">Gabriela Aljure</a>
    <nav class="nav" aria-label="Principal">
      {nav.map(item => (
        <a href={item.href} class={active === item.href ? 'active' : ''}>
          <span data-lang="es">{item.es}</span><span data-lang="en">{item.en}</span>
        </a>
      ))}
    </nav>
    <div class="toggles">
      <div class="toggle-group" role="group" aria-label="Language">
        <button class="toggle-btn active" data-toggle-lang="es" aria-pressed="true">ES</button>
        <span class="toggle-sep">·</span>
        <button class="toggle-btn" data-toggle-lang="en" aria-pressed="false">EN</button>
      </div>
      <div class="toggle-group" role="group" aria-label="Currency">
        <button class="toggle-btn" data-currency="COP" aria-pressed="false">COP</button>
        <span class="toggle-sep">·</span>
        <button class="toggle-btn active" data-currency="USD" aria-pressed="true">USD</button>
        <span class="toggle-sep">·</span>
        <button class="toggle-btn" data-currency="EUR" aria-pressed="false">EUR</button>
      </div>
    </div>
  </div>
</div>

<slot />

<footer>
  <div class="footer-inner">
    <span class="footer-name">Gabriela Pardo de Andrade Aljure</span>
    <a href="/politica-de-datos/" class="stripe-link"><span data-lang="es">Política de datos</span><span data-lang="en">Data policy</span></a>
    <span data-footer-text>© 2026 · Consultoría independiente</span>
  </div>
</footer>

<script is:inline>
  // ========== Language toggle ==========
  const langButtons = document.querySelectorAll('[data-toggle-lang]');
  const footerText = document.querySelector('[data-footer-text]');

  function setLanguage(lang) {
    document.documentElement.lang = lang;
    langButtons.forEach(b => {
      const isActive = b.dataset.toggleLang === lang;
      b.classList.toggle('active', isActive);
      b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
    footerText.textContent = lang === 'en'
      ? '© 2026 · Independent consultancy'
      : '© 2026 · Consultoría independiente';
    const activeCurrency = document.querySelector('[data-currency].active').dataset.currency;
    updatePrices(activeCurrency);
    try { localStorage.setItem('lang', lang); } catch (e) {}
  }

  langButtons.forEach(btn => {
    btn.addEventListener('click', () => setLanguage(btn.dataset.toggleLang));
  });

  // ========== Currency toggle ==========
  // USD y EUR son precios fijos (los que cobra Stripe). COP es display aproximado.
  // Actualizar RATE_COP_PER_USD periódicamente (jun 2026: ~3.600).
  const RATE_COP_PER_USD = 3600;

  function formatPrice(el, currency, lang) {
    const locale = lang === 'es' ? 'es-CO' : 'en-US';
    if (currency === 'USD') return `${parseInt(el.dataset.usd, 10).toLocaleString(locale)} USD`;
    if (currency === 'EUR') return `${parseInt(el.dataset.eur, 10).toLocaleString(locale)} EUR`;
    const cop = Math.round(parseInt(el.dataset.usd, 10) * RATE_COP_PER_USD / 10000) * 10000;
    return `${cop.toLocaleString(locale)} COP`;
  }

  function updatePrices(currency) {
    ['es', 'en'].forEach(sectionLang => {
      document.querySelectorAll(`[data-lang="${sectionLang}"]`).forEach(container => {
        container.querySelectorAll('[data-usd]').forEach(el => {
          const hasPrefix = el.dataset.prefix === 'true';
          const prefix = hasPrefix ? (sectionLang === 'en' ? 'From ' : 'Desde ') : '';
          const hadUnit = /unit/.test(el.innerHTML);
          const unit = hadUnit
            ? (sectionLang === 'en' ? '<span class="unit"> / mo</span>' : '<span class="unit"> / mes</span>')
            : '';
          el.innerHTML = `${prefix}${formatPrice(el, currency, sectionLang)}${unit}`;
        });
      });
    });
  }

  const currencyButtons = document.querySelectorAll('[data-currency]');
  currencyButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const currency = btn.dataset.currency;
      currencyButtons.forEach(b => {
        const isActive = b.dataset.currency === currency;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
      updatePrices(currency);
      try { localStorage.setItem('currency', currency); } catch (e) {}
    });
  });

  // ========== Load saved preferences ==========
  try {
    const savedLang = localStorage.getItem('lang');
    if (savedLang === 'en') setLanguage('en');
    const savedCurrency = localStorage.getItem('currency') || 'USD';
    if (savedCurrency !== 'USD') {
      document.querySelector(`[data-currency="${savedCurrency}"]`).click();
    } else {
      updatePrices('USD');
    }
  } catch (e) {}
</script>

<!-- GoatCounter analytics — sin cookies -->
<script data-goatcounter="https://gac.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

</body>
</html>
