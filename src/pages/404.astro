---
import Base from '../layouts/Base.astro';
---
<Base
  title="Página no encontrada — Gabriela Aljure"
  description="Esta página no existe."
>

<div data-lang="es">
  <section class="hero container">
    <div class="hero-eyebrow">Error 404</div>
    <h1 class="hero-title">Esta página <span class="accent">no existe</span>.</h1>
    <p class="hero-sub">El link que seguiste está roto o la página se movió. Lo que buscas probablemente está a un clic:</p>
    <a href="/" class="cta">Ir al inicio <span class="arrow">→</span></a>
  </section>
</div>

<div data-lang="en">
  <section class="hero container">
    <div class="hero-eyebrow">Error 404</div>
    <h1 class="hero-title">This page <span class="accent">doesn't exist</span>.</h1>
    <p class="hero-sub">The link you followed is broken or the page moved. What you're looking for is probably one click away:</p>
    <a href="/" class="cta">Go home <span class="arrow">→</span></a>
  </section>
</div>

</Base>
